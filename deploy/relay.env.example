# Copy this file to /etc/secure-chat/relay.env on a production server.
# Replace chat.example.com paths after issuing a real certificate.

# Keep plain HTTP bound to localhost for health checks and local reverse proxies.
SECURE_CHAT_RELAY_HTTP_ADDR=127.0.0.1:8787

# Public HTTPS and QUIC can share port 443 because one is TCP and one is UDP.
SECURE_CHAT_RELAY_HTTPS_ADDR=0.0.0.0:443
SECURE_CHAT_RELAY_QUIC_ADDR=0.0.0.0:443

# Signed UDP rendezvous used for P2P NAT traversal candidate discovery.
SECURE_CHAT_RELAY_P2P_ADDR=0.0.0.0:3478

# Use deploy/copy-letsencrypt-certs.sh to copy Let's Encrypt files here with
# permissions that the securechat service user can read.
SECURE_CHAT_TLS_CERT=/etc/secure-chat/tls/fullchain.pem
SECURE_CHAT_TLS_KEY=/etc/secure-chat/tls/privkey.pem

# Durable relay metadata and offline ciphertext queue.
SECURE_CHAT_RELAY_DB=/var/lib/secure-chat/relay.sqlite3

# Optional Apple APNs provider configuration. Leave unset to keep polling-only
# delivery; the relay will still accept signed token registration.
# SECURE_CHAT_APNS_TEAM_ID=TEAMID1234
# SECURE_CHAT_APNS_KEY_ID=KEYID12345
# SECURE_CHAT_APNS_PRIVATE_KEY_PATH=/etc/secure-chat/apns/AuthKey_KEYID12345.p8
# SECURE_CHAT_APNS_TOPIC_IOS=com.example.securechat
# SECURE_CHAT_APNS_TOPIC_MACOS=com.example.securechat.mac
# SECURE_CHAT_APNS_ENV=production

# Production log level. Use tower_http=info temporarily when debugging traffic.
RUST_LOG=secure_chat_relay=info,tower_http=warn
