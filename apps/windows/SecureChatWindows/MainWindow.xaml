<Window
    x:Class="SecureChatWindows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SecureChatWindows.ViewModels">

    <Grid
        x:Name="Root"
        Padding="16"
        RowSpacing="12"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        Loaded="Root_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" IsDynamicOverflowEnabled="True">
            <AppBarButton Label="Create/Login" Click="Bootstrap_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Contact" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Invite" Click="Invite_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Copy" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Temporary" Click="TemporaryInvite_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Clock" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Add Contact" Click="AddContact_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="AddFriend" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Start Temporary" Click="StartTemporary_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Link" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Receive" Click="Receive_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Refresh" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock Text="SecureChat Windows" Style="{ThemeResource TitleTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.ProfileLine, Mode=OneWay}" TextWrapping="Wrap" />
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="8">
                    <TextBox Header="Display name" Text="{x:Bind ViewModel.DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Header="Relay URL" Text="{x:Bind ViewModel.RelayUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Update Relay" Click="UpdateRelay_Click" HorizontalAlignment="Stretch" />
                </StackPanel>

                <ListView
                    x:Name="ConversationList"
                    Grid.Row="2"
                    ItemsSource="{x:Bind ViewModel.Conversations}"
                    SelectionChanged="ConversationList_SelectionChanged"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ConversationItem">
                            <StackPanel Padding="4">
                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Subtitle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                    <Button Content="Rename" Click="RenameContact_Click" />
                    <Button Content="Delete" Click="DeleteContact_Click" />
                    <Button Content="End temp" Click="EndTemporary_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.SelectedTitle, Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.SelectedSafetyNumber, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <ListView
                        x:Name="MessageList"
                        ItemsSource="{x:Bind ViewModel.VisibleMessages}"
                        Loaded="MessageList_Loaded"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:MessageItem">
                                <Border
                                    Margin="0,4"
                                    Padding="12"
                                    CornerRadius="8"
                                    BorderThickness="1"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Bind SenderLine}" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Bind DisplayText}" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                                        <Image
                                            Source="{x:Bind PreviewImage}"
                                            Visibility="{x:Bind PreviewImageVisibility}"
                                            MaxHeight="220"
                                            Stretch="Uniform"
                                            HorizontalAlignment="Left"
                                            Tag="{x:Bind}"
                                            Tapped="PreviewAttachment_Tapped" />
                                        <TextBlock Text="{x:Bind AttachmentSummary}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind StatusLine}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            <Button
                                                Content="Open attachment"
                                                Visibility="{x:Bind OpenAttachmentVisibility}"
                                                Tag="{x:Bind}"
                                                Click="OpenAttachment_Click" />
                                            <Button
                                                Content="Open burn"
                                                Visibility="{x:Bind BurnButtonVisibility}"
                                                Tag="{x:Bind}"
                                                Click="OpenBurn_Click" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button
                        x:Name="NewMessagesButton"
                        Content="New messages"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,16"
                        Click="NewMessages_Click" />
                </Grid>

                <Grid Grid.Row="2" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="ComposerBox"
                        PlaceholderText="Message"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        MinHeight="52" />
                    <Button Grid.Column="1" Content="Send" Click="Send_Click" />
                </Grid>

                <CommandBar Grid.Row="3" DefaultLabelPosition="Right">
                    <AppBarButton Label="File" Click="SendFile_Click" />
                    <AppBarButton Label="Image" Click="SendImage_Click" />
                    <AppBarButton Label="Burn" Click="SendBurn_Click" />
                    <AppBarButton Label="Import Sticker" Click="ImportSticker_Click" />
                    <AppBarElementContainer>
                        <ComboBox x:Name="StickerBox" ItemsSource="{x:Bind ViewModel.Stickers}" DisplayMemberPath="DisplayName" Width="180" PlaceholderText="Sticker" />
                    </AppBarElementContainer>
                    <AppBarButton Label="Send Sticker" Click="SendSticker_Click" />
                    <AppBarButton Label="Delete Sticker" Click="DeleteSticker_Click" />
                </CommandBar>
            </Grid>

            <Grid Grid.Column="2" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="Transfers" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.AttachmentTransfers}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="4">
                                <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Status}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <CheckBox Grid.Row="2" Content="Notify on new messages" IsChecked="{x:Bind ViewModel.NotifyOnNewMessages, Mode=TwoWay}" />
            </Grid>
        </Grid>

        <ProgressBar Grid.Row="2" IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
    </Grid>
</Window>
